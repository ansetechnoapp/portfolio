<script>
  function initTypingEffect() {
    const words = ["Développeur", "Designer", "Freelance", "Créatif"];
    const el = document.getElementById("typing-text");
    if (!el) return;

    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function type() {
      const current = words[wordIndex];

      if (isDeleting) {
        el.textContent = current.substring(0, charIndex - 1);
        charIndex--;
      } else {
        el.textContent = current.substring(0, charIndex + 1);
        charIndex++;
      }

      let delay = isDeleting ? 50 : 100;

      if (!isDeleting && charIndex === current.length) {
        delay = 2000;
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        delay = 300;
      }

      setTimeout(type, delay);
    }

    type();
  }

  function initTiltEffect() {
      const cards = document.querySelectorAll('.identity-card, .diagonal-card');
      
      cards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          
          const rotateX = ((y - centerY) / centerY) * 10;
          const rotateY = ((centerX - x) / centerX) * 10;
          
          // Fast transition for follow
          card.style.transition = 'transform 0.1s ease-out, box-shadow 0.1s ease-out';
          
          // Apply rotation with a slight scale
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-8px) scale(1.02)`;
          
          // Add dynamic glow follow
          const shadowX = (x - centerX) / 10;
          const shadowY = (y - centerY) / 10;
          card.style.boxShadow = `${shadowX}px ${shadowY}px 30px rgba(20, 184, 166, 0.2), 0 32px 64px rgba(0, 0, 0, 0.2)`;
        });
        
        card.addEventListener('mouseleave', () => {
          card.style.transition = 'transform 0.5s var(--ease-out-quint), box-shadow 0.5s ease';
          card.style.transform = '';
          card.style.boxShadow = '';
        });
      });
    }

    // Initialize both effects with a small check to prevent double execution
    if (!window.heroInitialized) {
      initTypingEffect();
      initTiltEffect();
      window.heroInitialized = true;
    }
    
    document.addEventListener("astro:page-load", () => {
      initTypingEffect();
      initTiltEffect();
    });
</script>
