---
interface Props {
  title: string;
  tagline?: string;
  tagline1?: string;
  align?: "start" | "center";
}

const { align = "center", tagline, tagline1, title } = Astro.props;
---

<div class:list={["hero-modern stack gap-4", align]}>
  <!-- Enhanced Background with Modern Gradient -->
  <div class="hero-background-modern">
    <div class="hero-gradient-overlay"></div>
  </div>

  <!-- Split Layout: Left (photo+name) | Right (content) -->
  <div class="hero-container-modern">
    <!-- LEFT: Image + Name -->
    <div class="hero-left">
      <div class="hero-image-container-modern">
        <div class="image-geometric-frame">
          <div class="frame-border"></div>
          <div class="frame-glow"></div>
        </div>
        <slot />
      </div>
      <h1 class="hero-title-modern">
        <span class="title-line-1">KEVIN</span>
        <span class="title-line-2 highlight-modern">OTTY</span>
      </h1>
    </div>

    <!-- RIGHT: Subtitle + Description + CTA -->
    <div class="hero-right">
      <h2 class="hero-subtitle-modern">
        <span class="typing-text">Développeur créatif</span>
        <br>
        <span class="subtitle-accent">transformant les idées en code</span>
      </h2>

      {tagline1 && (
        <p class="hero-description-modern">{tagline1}</p>
      )}

      <div class="hero-cta-container">
        <button class="cta-primary">
          <span>Parlons de votre projet</span>
          <div class="cta-glow"></div>
        </button>
        <a
          class="cta-secondary"
          href="https://bit.ly/CV_otty_kevin"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span>Voir mon CV</span>
          <svg class="cta-icon" width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator">
    <div class="scroll-mouse">
      <div class="scroll-dot"></div>
    </div>
    <span class="scroll-text">Scroll</span>
  </div>
</div>

<style>
  /* Modern Hero Styles */
  .hero-modern {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    /* Option 1: Ultra Subtle - Almost invisible gradient */
    /* background: linear-gradient(135deg,
      var(--gray-999) 0%,
      rgba(20, 25, 37, 0.3) 50%,
      var(--gray-999) 100%
    ); */

    /* Option 2: Soft Purple Tint - Uncomment to use */
    /* background: linear-gradient(135deg,
      var(--gray-999) 0%,
      rgba(116, 17, 166, 0.05) 30%,
      rgba(20, 25, 37, 0.4) 70%,
      var(--gray-999) 100%
    ); */

    /* Option 3: Teal Accent - Uncomment to use */
    background: linear-gradient(135deg,
      #ffffff2b 0%,
      rgba(20, 184, 166, 0.03) 20%,
      rgba(20, 25, 37, 0.2) 40%,
      var(--gray-999) 50%
    );

    /* Option 4: Radial Glow - Uncomment to use */
    /* background: radial-gradient(ellipse at center,
      rgba(20, 25, 37, 0.4) 0%,
      var(--gray-999) 70%
    ); */
  }

  /* Enhanced Modern Background */
  .hero-background-modern {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  .hero-gradient-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    /* Ultra transparent accent overlays */
    background: radial-gradient(circle at 30% 70%, rgba(116, 17, 166, 0.04), transparent 70%),
                radial-gradient(circle at 80% 20%, rgba(20, 184, 166, 0.03), transparent 70%),
                radial-gradient(circle at 60% 90%, rgba(99, 102, 241, 0.02), transparent 70%);
  }



  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--accent-teal);
    border-radius: 50%;
    opacity: 0.6;
    animation: floatParticle 15s ease-in-out infinite;
  }

  .particle-1 {
    top: 20%;
    left: 20%;
    animation-delay: 0s;
  }

  .particle-2 {
    top: 70%;
    right: 30%;
    animation-delay: -3s;
  }

  .particle-3 {
    bottom: 30%;
    left: 60%;
    animation-delay: -6s;
  }

  .particle-4 {
    top: 40%;
    right: 10%;
    animation-delay: -9s;
  }

  /* Split Container Layout */
  .hero-container-modern {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 8rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 6rem 3rem 3rem;
    width: 100%;
  }

  /* LEFT: Image + Name stacked */
  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* RIGHT: Content */
  .hero-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 500px;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s backwards;
  }

  /* Modern Title Styling */
  .hero-title-modern {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 0.95;
    margin: 0;
    letter-spacing: -0.02em;
    text-align: left;
  }

  .title-line-1 {
    display: block;
    color: var(--gray-0);
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s backwards;
  }

  .title-line-2 {
    display: block;
    background: linear-gradient(45deg, var(--accent-purple), var(--accent-teal), var(--accent-electric));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s backwards;
  }

  .highlight-modern {
    position: relative;
  }

  .highlight-modern::after {
    content: "";
    position: absolute;
    bottom: -0.1em;
    left: 0;
    right: 0;
    height: 0.3em;
    background: linear-gradient(45deg, var(--accent-purple), var(--accent-teal));
    opacity: 0.3;
    border-radius: 0.15em;
    animation: expandWidth 1s cubic-bezier(0.16, 1, 0.3, 1) 0.8s backwards;
  }

  /* Subtitle with Typing Effect */
  .hero-subtitle-modern {
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--gray-200);
    margin: 0;
    line-height: 1.4;
  }

  .typing-text {
    position: relative;
    color: var(--accent-teal);
  }

  .typing-text::after {
    content: "|";
    animation: blink 1s infinite;
    color: var(--accent-teal);
  }

  .subtitle-accent {
    color: var(--gray-300);
  }

  /* Description */
  .hero-description-modern {
    font-size: var(--text-base);
    color: var(--gray-400);
    line-height: 1.6;
    max-width: 500px;
    margin: 0;
  }

  /* CTA Buttons Container */
  .hero-cta-container {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
  }

  .cta-primary {
    position: relative;
    padding: 0.75rem 1.75rem;
    background: linear-gradient(45deg, var(--accent-purple), var(--accent-teal));
    border: none;
    border-radius: 0.75rem;
    color: white;
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(116, 17, 166, 0.3);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(116, 17, 166, 0.4);
  }

  .cta-primary:hover .cta-glow {
    opacity: 1;
  }

  .cta-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(45deg, rgba(255,255,255,0.2), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cta-secondary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    background: transparent;
    border: 2px solid var(--gray-600);
    border-radius: 0.75rem;
    color: var(--gray-200);
    font-weight: 600;
    font-size: var(--text-base);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cta-secondary:hover {
    border-color: var(--accent-teal);
    color: var(--accent-teal);
    transform: translateY(-2px);
  }

  .cta-icon {
    transition: transform 0.3s ease;
  }

  .cta-secondary:hover .cta-icon {
    transform: translateY(2px);
  }

  .hero-image-container-modern {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .image-geometric-frame {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 170px;
    height: 170px;
    z-index: -1;
  }

  .frame-border {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border: 1.5px solid var(--accent-teal);
    border-radius: 50%;
    opacity: 0.5;
    animation: pulse 3s ease-in-out infinite;
  }

  .frame-glow {
    position: absolute;
    top: -6px;
    left: -6px;
    right: -6px;
    bottom: -6px;
    background: linear-gradient(45deg, var(--accent-purple), var(--accent-teal), var(--accent-electric));
    border-radius: 50%;
    opacity: 0.1;
    filter: blur(12px);
    animation: pulse 3s ease-in-out infinite;
  }

  /* Animations */

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(50px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes wave {
    0%, 100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(20deg);
    }
    75% {
      transform: rotate(-10deg);
    }
  }

  @keyframes blink {
    0%, 50% {
      opacity: 1;
    }
    51%, 100% {
      opacity: 0;
    }
  }

  @keyframes expandWidth {
    from {
      width: 0;
    }
    to {
      width: 100%;
    }
  }

  @keyframes rotateBorder {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.1;
      transform: scale(1);
    }
    50% {
      opacity: 0.2;
      transform: scale(1.05);
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Scroll Indicator - Mouse */
  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 3;
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 1s backwards;
  }

  .scroll-mouse {
    width: 26px;
    height: 42px;
    border: 2px solid var(--gray-500);
    border-radius: 13px;
    display: flex;
    justify-content: center;
    padding-top: 8px;
    transition: border-color 0.3s ease;
  }

  .scroll-indicator:hover .scroll-mouse {
    border-color: var(--accent-teal);
  }

  .scroll-dot {
    width: 4px;
    height: 8px;
    background: var(--accent-teal);
    border-radius: 2px;
    animation: scrollDown 2s ease-in-out infinite;
  }

  @keyframes scrollDown {
    0% {
      opacity: 1;
      transform: translateY(0);
    }
    50% {
      opacity: 0.3;
      transform: translateY(14px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .scroll-text {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gray-400);
    font-weight: 500;
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-container-modern {
      flex-direction: column;
      gap: 2rem;
      padding: 5rem 1.5rem 2rem;
      text-align: center;
    }

    .scroll-indicator {
      display: none;
    }

    .hero-left {
      align-items: center;
    }

    .hero-right {
      align-items: center;
      text-align: center;
    }

    .hero-title-modern {
      font-size: clamp(2rem, 8vw, 3.5rem);
      text-align: center;
    }

    .hero-subtitle-modern {
      font-size: var(--text-xl);
    }

    .hero-description-modern {
      text-align: center;
    }

    .hero-cta-container {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-container-modern {
      padding: 4rem 1rem 1.5rem;
      gap: 1.5rem;
    }

    .hero-title-modern {
      font-size: clamp(1.75rem, 10vw, 2.5rem);
    }

    .hero-subtitle-modern {
      font-size: var(--text-lg);
    }

    .hero-description-modern {
      font-size: var(--text-sm);
    }

    .cta-primary,
    .cta-secondary {
      padding: 0.875rem 1.5rem;
      font-size: var(--text-sm);
    }
  }

  /* Additional CSS Variables for Modern Design */
  :root {
    --accent-teal: #14b8a6;
    --accent-electric: #6366f1;
    --accent-amber: #f59e0b;
    --accent-purple: #7611a6;
  }
</style>
