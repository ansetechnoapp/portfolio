---
import CallToAction from "./CallToAction.astro";
import Icon from "./reactJS/Icon";
import { getLangFromCookies, getTranslations } from "../i18n/index";
const lang = getLangFromCookies(Astro.cookies);
const i18n = getTranslations(lang);

const copyEmailLabel = i18n.contactCTA.copyEmail;
const copiedLabel = i18n.contactCTA.copied;
---

<aside class="contact-cta-premium" id="contact-cta">
  <div class="bg-noise"></div>
  <div class="background-blobs">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  
  <div class="premium-card-wrapper" id="premium-card">
    <div class="premium-container">
      <div class="spotlight"></div>
      <div class="card-glass-shine"></div>
      
      <div class="content-grid">
        <div class="text-content">
          <div class="status-badge" data-aos="fade-right">
            <span class="dot"></span>
            <span class="status-text">{i18n.contactCTA.available || "Available for new projects"}</span>
          </div>
          
          <h2 class="title-gradient" data-aos="fade-up">
            {i18n.contactCTA.title}
          </h2>
          <p class="subtitle" data-aos="fade-up" data-aos-delay="100">
            {i18n.contactCTA.subtitle}
          </p>
        </div>

        <div class="cta-actions" data-aos="fade-left">
          <div class="main-cta-group">
            <div class="primary-btn-wrapper magnetic-target">
              <CallToAction href="mailto:contact@zoddev.site">
                {i18n.contactCTA.button}
                <Icon icon="paper-plane-tilt" size="1.2em" />
              </CallToAction>
            </div>
            
            <button class="copy-email-btn" id="copy-email" 
              data-email="contact@zoddev.site" 
              data-copy-label={copyEmailLabel}
              data-copied-label={copiedLabel}
              aria-label={copyEmailLabel}>
              <span class="btn-content">
                <Icon icon="copy" size="1.2em" />
              </span>
              <span class="tooltip">{copyEmailLabel}</span>
            </button>
          </div>
          
          <div class="social-minimal-nav">
            <a href="https://www.linkedin.com/in/anscod/" aria-label="LinkedIn" class="social-item">
              <Icon icon="linkedin-logo" size="1.4em" />
            </a>
            <a href="https://github.com/ansetechnoapp" aria-label="GitHub" class="social-item">
              <Icon icon="github-logo" size="1.4em" />
            </a>
            <a href="https://x.com/ottianselme" aria-label="Twitter" class="social-item">
              <Icon icon="twitter-logo" size="1.4em" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  .contact-cta-premium {
    position: relative;
    padding-block: 10rem;
    margin-block: 4rem;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    perspective: 1200px;
  }

  .bg-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.05;
    z-index: 1;
    pointer-events: none;
  }

  .background-blobs {
    position: absolute;
    inset: 0;
    z-index: 0;
    filter: blur(100px);
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.2;
    animation: float 20s infinite alternate ease-in-out;
  }

  .blob-1 {
    top: 10%;
    right: 20%;
    width: 600px;
    height: 600px;
    background: var(--accent-light);
  }

  .blob-2 {
    bottom: 10%;
    left: 15%;
    width: 500px;
    height: 500px;
    background: var(--accent-secondary);
    animation-delay: -5s;
  }

  .blob-3 {
    top: 40%;
    left: 40%;
    width: 300px;
    height: 300px;
    background: #4facfe;
    animation-delay: -10s;
  }

  @keyframes float {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
  }

  .premium-card-wrapper {
    width: 100%;
    max-width: 2100px;
    margin-inline: 1.5rem;
    transition: transform 0.1s ease-out;
    z-index: 2;
  }

  .premium-container {
    position: relative;
    padding: 5rem 4rem;
    background: rgba(var(--gray-999-basis), 0.6);
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 40px;
    overflow: hidden;
    box-shadow: 
      0 40px 80px -20px rgba(255, 255, 255, 0.5),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  .spotlight {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      600px circle at var(--x, 50%) var(--y, 50%),
      rgba(var(--accent-light-rgb, 157, 78, 255), 0.1),
      transparent 40%
    );
    z-index: 1;
    pointer-events: none;
  }

  .card-glass-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg, 
      rgba(255, 255, 255, 0.1) 0%, 
      transparent 50%,
      rgba(255, 255, 255, 0.02) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .content-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }

  @media (min-width: 50em) {
    .content-grid {
      grid-template-columns: 1.3fr 0.7fr;
      gap: 6rem;
    }
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1.25rem;
    background: rgba(var(--accent-light-rgb, 157, 78, 255), 0.1);
    border: 1px solid rgba(var(--accent-light-rgb, 157, 78, 255), 0.3);
    border-radius: 100px;
    margin-bottom: 2.5rem;
    color: var(--accent-light);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .status-badge .dot {
    width: 10px;
    height: 10px;
    background: var(--accent-light);
    border-radius: 50%;
    box-shadow: 0 0 15px var(--accent-light);
    animation: blink 2s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .title-gradient {
    font-size: clamp(2.75rem, 7vw, 4rem);
    font-family: var(--font-display);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 2rem;
    letter-spacing: -0.02em;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
    background: linear-gradient(
      to bottom right, 
      var(--gray-0) 0%, 
      var(--gray-100) 50%,
      var(--gray-400) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: var(--text-xl);
    color: var(--gray-300);
    line-height: 1.5;
    max-width: 40ch;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 50em) {
    .cta-actions {
      align-items: flex-end;
    }
  }

  .main-cta-group {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .primary-btn-wrapper {
    transition: transform 0.2s cubic-bezier(0.17, 0.67, 0.83, 0.67);
  }

  .copy-email-btn {
    position: relative;
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    color: var(--gray-200);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .copy-email-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: white;
    transform: scale(1.05);
  }

  .copy-email-btn.success {
    background: #00c853;
    border-color: #00c853;
    color: white;
  }

  .copy-email-btn .tooltip {
    position: absolute;
    bottom: 120%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    padding: 0.5rem 1rem;
    background: black;
    color: white;
    font-size: 0.75rem;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
  }

  .copy-email-btn:hover .tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .social-minimal-nav {
    display: flex;
    gap: 1.25rem;
  }

  .social-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 18px;
    color: var(--gray-400);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .social-item:hover {
    background: white;
    color: black;
    transform: translateY(-8px) rotate(8deg);
    box-shadow: 0 15px 30px rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 480px) {
    .premium-container {
      padding: 4rem 2rem;
      border-radius: 30px;
    }
    
    .title-gradient {
      font-size: 2.5rem;
    }

    .main-cta-group {
      flex-direction: column;
      width: 100%;
    }

    .copy-email-btn {
      width: 100%;
      height: 54px;
    }
  }
</style>

<script>
  function initContactEffects() {
    const cardWrapper = document.getElementById('premium-card');
    const container = cardWrapper?.querySelector('.premium-container') as HTMLElement;
    const copyBtn = document.getElementById('copy-email');
    const magneticTargets = document.querySelectorAll('.magnetic-target');

    if (!cardWrapper || !container) return;

    cardWrapper.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = cardWrapper.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;

      container.style.setProperty('--x', `${x}px`);
      container.style.setProperty('--y', `${y}px`);

      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 30;
      const rotateY = (centerX - x) / 30;

      cardWrapper.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
    });

    cardWrapper.addEventListener('mouseleave', () => {
      cardWrapper.style.transform = 'rotateX(0deg) rotateY(0deg)';
    });

    magneticTargets.forEach((target) => {
      target.addEventListener('mousemove', (e: any) => {
        const rect = target.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        (target as HTMLElement).style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });

      target.addEventListener('mouseleave', () => {
        (target as HTMLElement).style.transform = `translate(0, 0)`;
      });
    });

    copyBtn?.addEventListener('click', async () => {
      const email = copyBtn.getAttribute('data-email') || '';
      const copyLabel = copyBtn.getAttribute('data-copy-label') || '';
      const copiedLabel = copyBtn.getAttribute('data-copied-label') || '';
      const tooltip = copyBtn.querySelector('.tooltip');

      try {
        await navigator.clipboard.writeText(email);
        copyBtn.classList.add('success');
        if (tooltip) tooltip.textContent = copiedLabel;
        
        setTimeout(() => {
          copyBtn.classList.remove('success');
          if (tooltip) tooltip.textContent = copyLabel;
        }, 2000);
      } catch (err) {
        console.error('Failed to copy email:', err);
      }
    });
  }

  document.addEventListener('astro:page-load', initContactEffects);
  initContactEffects();
</script>
